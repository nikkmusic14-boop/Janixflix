{
  "name": "janixflix",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "description": "JaNixFlix - self-hosted movie streaming platform (full stack)",
  "scripts": {
    "postinstall": "npm install --prefix server",
    "start": "node server/src/index.js",
    "install:all": "npm install --prefix server && npm install --prefix client",
    "build": "npm run install:all && npm run build --prefix client",
    "dev": "concurrently -n SERVER,CLIENT -c red,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "server": "npm start --prefix server",
    "client": "npm run dev --prefix client",
    "deploy": "node deploy-render.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "main": "check-render.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikkmusic14-boop/Janixflix.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/nikkmusic14-boop/Janixflix/issues"
  },
  "homepage": "https://github.com/nikkmusic14-boop/Janixflix#readme"
}
